<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:dir2site.ViewModels"
        xmlns:v="using:dir2site.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="dir2site.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app/dir2site-icon.png"
        Title="dir2site">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Status bar pinned to bottom -->
        <Border DockPanel.Dock="Bottom"
                Background="#1A1A1A"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}"
                             Width="120"
                             Height="8"
                             VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}"
                           FontSize="12"
                           Foreground="#E0E0E0"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <!-- Toolbar: always visible -->
        <Border DockPanel.Dock="Top" Padding="8,6" BorderBrush="#333" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Label VerticalAlignment="Center">Site Project Folder:</Label>
                <TextBlock Text="{Binding DirectoryRoot}"
                           FontSize="14"
                           VerticalAlignment="Center"/>
                <Button Content="Choose…" Command="{Binding SelectDirectoryCommand}"/>
            </StackPanel>
        </Border>

        <!-- Update notification banner -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemAccentColor}"
                Padding="10,6"
                IsVisible="{Binding UpdateAvailable}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{Binding UpdateVersion, StringFormat='Update available: v{0}'}"
                           FontSize="12"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <ProgressBar Value="{Binding UpdateProgress}"
                             Minimum="0" Maximum="100"
                             Width="100" Height="8"
                             VerticalAlignment="Center"
                             IsVisible="{Binding UpdateProgress, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <Button Content="Download"
                        Command="{Binding DownloadUpdateCommand}"
                        FontSize="11" Padding="8,3"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemAccentColor}"
                Padding="10,6"
                IsVisible="{Binding UpdateReady}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{Binding UpdateVersion, StringFormat='v{0} ready to install'}"
                           FontSize="12"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <Button Content="Restart &amp; Install"
                        Command="{Binding RestartAndUpdateCommand}"
                        FontSize="11" Padding="8,3"/>
            </StackPanel>
        </Border>

        <!-- Fill area: welcome panel or content, whichever is active -->
        <Panel>

            <!-- Welcome panel: visible before a folder is chosen -->
            <ScrollViewer IsVisible="{Binding DirectoryRoot, Converter={x:Static StringConverters.IsNullOrEmpty}}">
            <Grid ColumnDefinitions="Auto,*"
                  Margin="40,32"
                  VerticalAlignment="Top">
                <Image Grid.Column="0"
                       Source="/Assets/app/dir2site-icon.png"
                       Width="160" Height="160"
                       VerticalAlignment="Top"
                       Margin="0,0,40,0"/>
                <StackPanel Grid.Column="1" Spacing="12">
                    <TextBlock Text="Dir2Site" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Turn any folder into a polished static website — instantly."
                               FontSize="15" TextWrapping="Wrap"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13">
                        <Run FontWeight="SemiBold">Your filesystem is your CMS</Run>
                        <Run> — metadata lives in YAML files alongside your content, trackable in git. No database, no lock-in.</Run>
                    </TextBlock>

                    <TextBlock Text="Getting Started" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <StackPanel Spacing="5">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock FontSize="13" Text="1." VerticalAlignment="Center"/>
                            <Button Content="Choose…" Command="{Binding SelectDirectoryCommand}"
                                    FontSize="13" Padding="6,2" VerticalAlignment="Center"/>
                            <TextBlock FontSize="13" Text="— select your site project folder" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock FontSize="13">
                            <Run>2.</Run>
                            <Run> Adjust site settings — title, footer, colors, logo</Run>
                        </TextBlock>
                        <TextBlock FontSize="13">
                            <Run>3.</Run>
                            <Run FontWeight="SemiBold"> Generate Site</Run>
                            <Run> — static HTML written to a </Run>
                            <Run FontFamily="Courier New" FontSize="12">_site/</Run>
                            <Run> subfolder</Run>
                        </TextBlock>
                        <TextBlock FontSize="13">
                            <Run>4.</Run>
                            <Run FontWeight="SemiBold"> ▶ Start</Run>
                            <Run> — launch a local preview and open in browser</Run>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Text="Supported Content" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <StackPanel Spacing="5">
                        <TextBlock FontSize="13"><Run FontWeight="SemiBold">Photos</Run><Run> — full-screen gallery with deep-zoom viewer and optional annotations</Run></TextBlock>
                        <TextBlock FontSize="13"><Run FontWeight="SemiBold">PDFs</Run><Run> — embedded document reader</Run></TextBlock>
                        <TextBlock FontSize="13"><Run FontWeight="SemiBold">Markdown</Run><Run> — .md files rendered as web articles</Run></TextBlock>
                        <TextBlock FontSize="13"><Run FontWeight="SemiBold">Folders</Run><Run> — become browsable collection pages</Run></TextBlock>
                    </StackPanel>
                </StackPanel>
            </Grid>
            </ScrollViewer>

            <ScrollViewer IsVisible="{Binding DirectoryRoot, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <StackPanel>

                <Border IsVisible="{Binding Dir2SiteConfig, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Margin="8" Padding="12" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Site Settings" FontWeight="Bold" FontSize="14"/>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Label Width="140">Title</Label>
                            <TextBox Text="{Binding Dir2SiteConfig.Title}" Width="260"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Label Width="140">Footer</Label>
                            <TextBox Text="{Binding Dir2SiteConfig.Footer}" Width="260"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Label Width="140">Site URL</Label>
                            <TextBox Text="{Binding Dir2SiteConfig.SiteUrl}" Width="260" Watermark="https://example.com"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Label Width="140">Logo (filename)</Label>
                            <TextBox Text="{Binding Dir2SiteConfig.Logo}" Width="200"/>
                            <Button Content="Choose..." Command="{Binding ChooseLogoCommand}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Label Width="140">Primary Color</Label>
                            <TextBox Text="{Binding Dir2SiteConfig.PrimaryColor}" Width="120"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Label Width="140">Secondary Color</Label>
                            <TextBox Text="{Binding Dir2SiteConfig.SecondaryColor}" Width="120"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Label Width="140">Background Color</Label>
                            <TextBox Text="{Binding Dir2SiteConfig.BackgroundColor}" Width="120"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Label Width="140">Navbar Style</Label>
                            <RadioButton GroupName="NavbarStyle" Content="Dark" IsChecked="{Binding Dir2SiteConfig.NavbarDark}"/>
                            <RadioButton GroupName="NavbarStyle" Content="Light" IsChecked="{Binding Dir2SiteConfig.NavbarDark, Converter={x:Static BoolConverters.Not}}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                            <Button Content="Generate Site"
                                    Command="{Binding GenerateSiteCommand}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0" VerticalAlignment="Center">
                            <Button Content="▶ Start"
                                    Command="{Binding StartServerCommand}"
                                    IsVisible="{Binding !IsServerRunning}"
                                    FontSize="11"
                                    Padding="6,3"/>
                            <Button Content="■ Stop"
                                    Command="{Binding StopServerCommand}"
                                    IsVisible="{Binding IsServerRunning}"
                                    FontSize="11"
                                    Padding="6,3"/>
                            <Button Content="{Binding ServerUrl}"
                                    Command="{Binding OpenBrowserCommand}"
                                    IsVisible="{Binding IsServerRunning}"
                                    Cursor="Hand"
                                    FontSize="11"
                                    Foreground="#4A9EFF"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="2,0"
                                    VerticalAlignment="Center"/>
                            <Button Content="Open in Browser"
                                    Command="{Binding OpenBrowserCommand}"
                                    IsVisible="{Binding IsServerRunning}"
                                    FontSize="11"
                                    Padding="6,3"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TreeView ItemsSource="{Binding DirItems}"
                          SelectedItem="{Binding SelectedItem}">
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate DataType="vm:DirectoryTreeItem"
                                          ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                <Panel IsVisible="{Binding ArtifactViewModel, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <v:ArtifactView DataContext="{Binding ArtifactViewModel}"></v:ArtifactView>
                                </Panel>
                            </StackPanel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </StackPanel>
        </ScrollViewer>

        </Panel>

    </DockPanel>
    
</Window>
